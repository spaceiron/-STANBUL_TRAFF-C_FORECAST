# Copy to .env for local backend (optional)
# Render: set same keys in Dashboard → Environment

# Live vehicle positions (optional)
IBB_TRAFFIC_API_URL=
IBB_STOPS_API_URL=
IBB_API_KEY=
IBB_API_KEY_HEADER=apikey
IBB_ROUTE_PARAM=routeId
IBB_STOPS_ROUTE_PARAM=routeId
IBB_TIMEOUT_SEC=5

APP_DEBUG=1
PORT=5000

# Comma-separated admin emails (optional). If set, admin API requires header X-User-Email.
ADMIN_EMAILS=demor.uzay@gmail.com
